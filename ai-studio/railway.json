{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "dockerfilePath": "Dockerfile.backend"
  },
  "deploy": {
    "services": {
      "api": {
        "startCommand": "uvicorn backend.main:app --host 0.0.0.0 --port $PORT",
        "healthcheckPath": "/health"
      },
      "worker": {
        "startCommand": "python -m backend.worker"
      }
    }
  }
}
